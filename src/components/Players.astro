interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = getT(lang);

function slugify(name: string) {
  return name
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

function getAvatarPath(name: string): string | undefined {
  const filename = `${slugify(name)}.webp`;
  const fullPath = path.join(process.cwd(), 'public', 'fichas', filename);
  return fs.existsSync(fullPath) ? `/fichas/${filename}` : undefined;
}

