---
import { getT, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = getT(lang);
const otherLangHref = lang === 'es' ? '/en/' : '/';
const otherLangLabel = lang === 'es' ? 'EN' : 'ES';

const navItems = [
  { label: t.nav.nosotros, href: '#nosotros' },
  { label: t.nav.jugadores, href: '#jugadores' },
  { label: t.nav.servicios, href: '#servicios' },
  { label: t.nav.contacto, href: '#contacto' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300 bg-transparent"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-10 flex items-center justify-between h-20">
    <a href="#top" class="flex items-center gap-3">
      <img src="/logo-shield.webp" alt="Revival Football" class="h-10 w-auto" />
      <span class="font-display text-xl tracking-widest uppercase text-bone">
        Revival<span class="text-gradient-gold">Football</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm uppercase tracking-wider text-bone/80 hover:text-gold transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:flex items-center gap-4">
      <a
        href={otherLangHref}
        class="text-sm uppercase tracking-wider text-bone/60 hover:text-gold transition-colors border border-white/15 hover:border-gold rounded-full px-3 py-1"
      >
        {otherLangLabel}
      </a>
      <a
        href="mailto:ggonzalez@revivalfootball.com"
        class="inline-flex items-center border border-gold text-gold px-5 py-2 text-sm uppercase tracking-wider hover:bg-gold hover:text-ink transition-colors"
      >
        {t.nav.contactar}
      </a>
    </div>

    <button
      id="menu-toggle"
      class="md:hidden text-bone"
      aria-label={t.nav.openMenu}
      aria-expanded="false"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="md:hidden hidden flex-col bg-ink-soft border-t border-white/10">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="block px-6 py-4 text-sm uppercase tracking-wider text-bone/80 hover:text-gold border-b border-white/5"
        >
          {item.label}
        </a>
      ))
    }
    <a
      href="mailto:ggonzalez@revivalfootball.com"
      class="block px-6 py-4 text-sm uppercase tracking-wider text-gold"
    >
      {t.nav.contactar}
    </a>
    <a
      href={otherLangHref}
      class="block px-6 py-4 text-sm uppercase tracking-wider text-bone/60 border-t border-white/5"
    >
      {otherLangLabel}
    </a>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const onScroll = () => {
    if (window.scrollY > 40) {
      header?.classList.add('bg-ink/90', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/30');
      header?.classList.remove('bg-transparent');
    } else {
      header?.classList.remove('bg-ink/90', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/30');
      header?.classList.add('bg-transparent');
    }
  };

  document.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('flex');
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
