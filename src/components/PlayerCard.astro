---
interface Props {
  name: string;
  club: string;
  position: string;
  category: string;
  avatar?: string;
  transfermarkt?: string;
  video?: string;
  copyIndex: number;
  verTransfermarktLabel: string;
  verHighlightsLabel: string;
  noStatsLabel: string;
}

const {
  name,
  club,
  position,
  category,
  avatar,
  transfermarkt,
  video,
  copyIndex,
  verTransfermarktLabel,
  verHighlightsLabel,
  noStatsLabel,
} = Astro.props;
---

<div
  data-reveal
  data-category={category}
  data-name={name}
  data-club={club}
  data-position={position}
  data-transfermarkt={transfermarkt ?? ''}
  data-video={video ?? ''}
  data-copy={copyIndex}
  class="player-card group relative shrink-0 flex h-[240px] sm:h-[280px] w-[170px] sm:w-[200px] sm:hover:w-[540px] border border-white/10 sm:hover:border-gold/60 bg-ink-soft overflow-hidden transition-[width] duration-500 ease-in-out cursor-pointer"
>
  <div class="relative h-full w-[170px] sm:w-[200px] shrink-0">
    {avatar ? (
      <img
        src={avatar}
        alt={name}
        draggable="false"
        class="absolute inset-0 w-full h-full object-cover object-top bg-white pointer-events-none select-none"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <p class="font-display text-6xl text-white/5 select-none">
          {name.split(' ').map((n) => n[0]).join('')}
        </p>
      </div>
    )}

    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/30 to-transparent opacity-100 sm:group-hover:opacity-0 transition-opacity duration-200" />
    <div class="absolute bottom-0 left-0 right-0 p-4 opacity-100 sm:group-hover:opacity-0 transition-opacity duration-200">
      <p class="text-gold text-[10px] uppercase tracking-widest mb-0.5">{position}</p>
      <p class="font-display text-base text-bone leading-tight">{name}</p>
      <p class="text-bone/50 text-xs mt-0.5">{club}</p>
    </div>
  </div>

  <div class="hidden sm:flex flex-col justify-center gap-5 p-6 w-[310px] sm:w-[340px] shrink-0 opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 delay-150 ease-out">
    <div>
      <p class="text-gold text-[11px] uppercase tracking-widest mb-1">{position}</p>
      <p class="font-display text-xl text-bone leading-tight">{name}</p>
      <p class="text-bone/50 text-sm mt-1">{club}</p>
    </div>

    <div class="flex flex-wrap gap-3">
      {transfermarkt && (
        <a
          href={transfermarkt}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-fit items-center gap-2 border border-gold text-gold px-5 py-2.5 text-xs uppercase tracking-widest hover:bg-gold hover:text-ink transition-colors"
        >
          {verTransfermarktLabel}
        </a>
      )}
      {video && (
        <a
          href={video}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-fit items-center gap-2 border border-bone/30 text-bone px-5 py-2.5 text-xs uppercase tracking-widest hover:border-gold hover:text-gold transition-colors"
        >
          {verHighlightsLabel}
        </a>
      )}
    </div>
    {!transfermarkt && !video && (
      <p class="text-bone/40 text-xs">{noStatsLabel}</p>
    )}
  </div>
</div>
