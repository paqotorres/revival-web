---
interface Props {
  class?: string;
  color?: string;
}

const {
  class: className = 'absolute inset-0 w-full h-full opacity-[0.05] -z-10 pointer-events-none',
  color = '#f5f3ef',
} = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 1050 680"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <g stroke={color} stroke-width="2" fill="none" vector-effect="non-scaling-stroke">
    <rect x="20" y="20" width="1010" height="640" />
    <line x1="525" y1="20" x2="525" y2="660" />
    <circle cx="525" cy="340" r="91.5" />
    <circle cx="525" cy="340" r="4" fill={color} stroke="none" />

    <rect x="20" y="164" width="176" height="352" />
    <rect x="20" y="263" width="59" height="154" />
    <circle cx="152" cy="340" r="4" fill={color} stroke="none" />
    <path d="M 196 260 A 91.5 91.5 0 0 1 196 420" />
    <rect x="4" y="300" width="16" height="80" />

    <rect x="854" y="164" width="176" height="352" />
    <rect x="971" y="263" width="59" height="154" />
    <circle cx="898" cy="340" r="4" fill={color} stroke="none" />
    <path d="M 854 260 A 91.5 91.5 0 0 0 854 420" />
    <rect x="1030" y="300" width="16" height="80" />

    <path d="M 20 44 A 24 24 0 0 1 44 20" />
    <path d="M 44 660 A 24 24 0 0 1 20 636" />
    <path d="M 1030 44 A 24 24 0 0 0 1006 20" />
    <path d="M 1006 660 A 24 24 0 0 0 1030 636" />
  </g>
</svg>
