---
import { getT, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = getT(lang);
const year = new Date().getFullYear();
---

<footer id="contacto" class="bg-ink-soft border-t border-white/10">
  <div class="mx-auto max-w-7xl px-6 lg:px-10 py-16 grid gap-12 md:grid-cols-2">
    <div data-reveal>
      <img src="/logo-full.webp" alt="Revival Football - International Football Management" class="h-24 w-auto mb-4" />
      <p class="text-bone/60 text-sm leading-relaxed max-w-xs mb-6">
        {t.footer.description}
      </p>
      <div class="flex items-center gap-3">
        <a
          href="https://www.instagram.com/revivalfootball/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="h-10 w-10 flex items-center justify-center rounded-full border border-white/15 text-bone/70 hover:border-gold hover:text-gold transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4.2" />
            <circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=100083981581276"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="h-10 w-10 flex items-center justify-center rounded-full border border-white/15 text-bone/70 hover:border-gold hover:text-gold transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M13.5 21v-7.6h2.55l.38-2.96h-2.93V8.55c0-.86.24-1.44 1.47-1.44h1.57V4.46A21 21 0 0 0 14.2 4.3c-2.15 0-3.62 1.31-3.62 3.72v2.42H8v2.96h2.58V21h2.92Z" />
          </svg>
        </a>
      </div>
    </div>

    <div data-reveal data-reveal-delay="1">
      <p class="text-gold text-sm uppercase tracking-widest mb-4">{t.footer.contacto}</p>
      <ul class="space-y-2 text-bone/70 text-sm">
        <li>
          <a href="mailto:ggonzalez@revivalfootball.com" class="hover:text-gold transition-colors">
            ggonzalez@revivalfootball.com
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 py-6">
    <p class="text-center text-bone/40 text-xs tracking-wide">
      © {year} Revival Football. {t.footer.rights}
    </p>
  </div>
</footer>
