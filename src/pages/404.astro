---
import Layout from '../layouts/Layout.astro';
---

<Layout lang="es" title="Página no encontrada | Revival Football">
  <section class="relative z-0 min-h-[70vh] flex items-center justify-center bg-ink py-28 px-6 text-center">
    <div>
      <p class="text-gold uppercase tracking-[0.3em] text-xs mb-4">Error 404</p>
      <h1 class="font-display uppercase text-4xl md:text-6xl leading-tight text-bone mb-6">
        Página <span class="text-gradient-gold">no encontrada</span>
      </h1>
      <p class="text-bone/60 max-w-md mx-auto mb-10 leading-relaxed">
        El enlace que buscas no existe o fue movido.
      </p>
      <a
        href="/"
        class="inline-flex items-center bg-gold text-ink px-8 py-4 text-sm uppercase tracking-widest font-medium hover:bg-gold-light transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</Layout>
